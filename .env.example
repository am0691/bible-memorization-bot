# Discord Bot Token (from Developer Portal)
DISCORD_TOKEN=your_bot_token_here

# Server (Guild) ID
GUILD_ID=your_guild_id_here

# Channel IDs
CERTIFICATION_CHANNEL_ID=your_certification_channel_id
REPORT_CHANNEL_ID=your_report_channel_id

# Admin Discord User ID (for error notifications)
ADMIN_DISCORD_ID=your_admin_discord_id

# Schedule Settings
DAILY_REMINDER_TIME=07:00
TIMEZONE=Asia/Seoul
